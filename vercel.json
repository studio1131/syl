{
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/static/(.*)", "destination": "/studio-build/static/$1" },
    { "source": "/studio",      "destination": "/studio-build/index.html" },
    { "source": "/studio/(.*)", "destination": "/studio-build/index.html" }
  ],
  "headers": [
    {
      "source": "/studio(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",         "value": "DENY" },
        { "key": "X-XSS-Protection",        "value": "1; mode=block" },
        { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",      "value": "camera=(), microphone=(), geolocation=()" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self' https://*.sanity.io https://*.apicdn.sanity.io; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https: blob:; connect-src 'self' https://cdn.sanity.io https://*.apicdn.sanity.io https://api.sanity.io wss://*.sanity.io; media-src 'self' https://cdn.sanity.io blob:; worker-src 'self' blob:"
        }
      ]
    }
  ]
}
